NODE_ENV=development
PORT=3000

# Comma-separated list for multiple origins; fallback CLIENT_URL is also supported by the app.
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173

# Core backend secrets
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>
JWT_SECRET=<generate-a-strong-random-secret>
APP_ENCRYPTION_KEY=<64-char-hex-key>

# Plaid
PLAID_CLIENT_ID=<plaid-client-id>
PLAID_SECRET=<plaid-secret>
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US
PLAID_REDIRECT_URI=http://localhost:5173/oauth-callback
PLAID_WEBHOOK_URL=https://example.ngrok.io/api/plaid/webhook

# Alpaca
ALPACA_API_KEY=<alpaca-api-key>
ALPACA_SECRET_KEY=<alpaca-secret-key>
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_DEFAULT_TIF=day

# Advisor provider: openai | gemini | openrouter
ADVISOR_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=<openai-api-key>
OPENAI_ADVISOR_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=

# Gemini
GEMINI_API_KEY=<gemini-api-key>
GEMINI_ADVISOR_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=

# OpenRouter
OPENROUTER_API_KEY=<openrouter-api-key>
OPENROUTER_ADVISOR_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
